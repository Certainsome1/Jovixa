PROJECT_NAME="AI Job Matcher API"
API_VERSION="0.1.0"
API_V1_PREFIX="/api/v1"
DEBUG=false

DATABASE_URL="sqlite+aiosqlite:///./ai_job_matcher.db"
AUTO_CREATE_TABLES=true
CORS_ORIGINS="http://localhost:3000"
UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_MB=10

DEFAULT_JOB_QUERY="Teamcenter NX PLM"
DEFAULT_JOB_LOCATION="India"
LINKEDIN_JOB_SEARCH_URL_TEMPLATE="https://www.linkedin.com/jobs-guest/jobs/api/seeMoreJobPostings/search?keywords={query}&location={location}&start=0"
INDEED_JOB_FEED_URL_TEMPLATE="https://rss.indeed.com/rss?q={query}&l={location}"
ARBEITNOW_JOB_API_URL_TEMPLATE="https://www.arbeitnow.com/api/job-board-api"
REMOTIVE_JOB_API_URL_TEMPLATE="https://remotive.com/api/remote-jobs?search={query}"
ORGANIZATION_JOB_BOARD_URLS=""
JOB_SOURCE_VERIFY_SSL=false
ENABLE_JOB_SCHEDULER=false
JOB_FETCH_INTERVAL_SECONDS=3600
EMBEDDING_DIMENSIONS=384
